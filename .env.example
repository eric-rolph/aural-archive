# Optional: Google Gemini API key for visual (video) transcription
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: Override auto-detected ffmpeg path
# FFMPEG_PATH=C:\path\to\ffmpeg.exe

# Optional: Override auto-detected ffprobe path
# FFPROBE_PATH=C:\path\to\ffprobe.exe
